{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm",
    "analytics": false
  },
  "newProjectRoot": "projects",
  "projects": {
    "angular-puglite-demo": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "inlineTemplate": true,
          "inlineStyle": true,
          "skipTests": true
        },
        "@schematics/angular:class": {
          "skipTests": true
        },
        "@schematics/angular:directive": {
          "skipTests": true
        },
        "@schematics/angular:guard": {
          "skipTests": true
        },
        "@schematics/angular:interceptor": {
          "skipTests": true
        },
        "@schematics/angular:pipe": {
          "skipTests": true
        },
        "@schematics/angular:resolver": {
          "skipTests": true
        },
        "@schematics/angular:service": {
          "skipTests": true
        }
      },
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "puglite:browser",
          "options": {
            "outputPath": "dist/angular-puglite-demo",
            "index": "src/index.html",
            "main": "src/main.ts",
            "tsConfig": "tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "public"
              }
            ],
            "styles": ["src/styles.css"]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "puglite:dev-server",
          "options": {
            "buildTarget": "angular-puglite-demo:build:development"
          },
          "configurations": {
            "production": {
              "buildTarget": "angular-puglite-demo:build:production"
            },
            "development": {
              "buildTarget": "angular-puglite-demo:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "build-webdiscus": {
          "builder": "@angular-builders/custom-webpack:browser",
          "options": {
            "customWebpackConfig": {
              "path": "./webpack.config.js"
            },
            "outputPath": "dist/angular-puglite-demo-webdiscus",
            "index": "src/index.html",
            "main": "src/main.ts",
            "tsConfig": "tsconfig.app.json",
            "aot": true,
            "assets": [
              {
                "glob": "**/*",
                "input": "public"
              }
            ],
            "styles": ["src/styles.css"]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "build-esbuild": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": "dist/angular-puglite-demo-esbuild",
            "index": "src/index.html",
            "browser": "src/main-esbuild.ts",
            "tsConfig": "tsconfig.esbuild.json",
            "aot": true,
            "assets": [
              {
                "glob": "**/*",
                "input": "public"
              }
            ],
            "styles": ["src/styles.css"]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "build-custom-esbuild": {
          "builder": "@angular-builders/custom-esbuild:application",
          "options": {
            "plugins": ["./esbuild/pug-fs-intercept-plugin.js"],
            "outputPath": "dist/angular-puglite-demo-custom-esbuild",
            "index": "src/index.html",
            "browser": "src/main-custom-esbuild.ts",
            "tsConfig": "tsconfig.custom-esbuild.json",
            "aot": true,
            "assets": [
              {
                "glob": "**/*",
                "input": "public"
              }
            ],
            "styles": ["src/styles.css"]
          },
          "configurations": {
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "development"
        },
        "build-application": {
          "builder": "puglite:application",
          "options": {
            "plugins": ["./esbuild/banner-marker-plugin.js"],
            "outputPath": {
              "base": "dist/angular-puglite-demo-application",
              "browser": ""
            },
            "index": "src/index.html",
            "browser": "src/main-custom-esbuild.ts",
            "tsConfig": "tsconfig.custom-esbuild.json",
            "aot": true,
            "assets": [
              {
                "glob": "**/*",
                "input": "public"
              }
            ],
            "styles": ["src/styles.css"]
          },
          "configurations": {
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "development"
        },
        "serve-application": {
          "builder": "puglite:application-dev-server",
          "options": {
            "buildTarget": "angular-puglite-demo:build-application:development",
            "port": 4299
          }
        },
        "serve-webdiscus": {
          "builder": "@angular-builders/custom-webpack:dev-server",
          "options": {
            "buildTarget": "angular-puglite-demo:build-webdiscus:development"
          },
          "configurations": {
            "production": {
              "buildTarget": "angular-puglite-demo:build-webdiscus:production"
            },
            "development": {
              "buildTarget": "angular-puglite-demo:build-webdiscus:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "puglite:vitest",
          "options": {}
        },
        "test-karma": {
          "builder": "puglite:karma",
          "options": {
            "karmaConfig": "karma.conf.js",
            "main": "src/test.ts",
            "polyfills": ["zone.js", "zone.js/testing"],
            "tsConfig": "tsconfig.karma.spec.json",
            "include": ["**/*.karma.spec.ts"],
            "assets": [
              {
                "glob": "**/*",
                "input": "public",
                "output": "/"
              }
            ],
            "styles": ["src/styles.css"]
          }
        }
      }
    }
  }
}
